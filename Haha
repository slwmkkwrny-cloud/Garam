-- ============ FUNCTIONS ============

local function animateToggle(button, statusLabel, enabled)
    local TweenService = game:GetService("TweenService")
    if enabled then
        button.Text = "ON"
        button.TextColor3 = Color3.fromRGB(255, 255, 255)
        statusLabel.Text = "Status: ON"
        statusLabel.TextColor3 = Color3.fromRGB(80, 255, 140)
        TweenService:Create(button, TweenInfo.new(0.25, Enum.EasingStyle.Quart), {
            BackgroundColor3 = Color3.fromRGB(60, 200, 100)
        }):Play()
    else
        button.Text = "OFF"
        button.TextColor3 = Color3.fromRGB(180, 180, 200)
        statusLabel.Text = "Status: OFF"
        statusLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
        TweenService:Create(button, TweenInfo.new(0.25, Enum.EasingStyle.Quart), {
            BackgroundColor3 = Color3.fromRGB(60, 60, 80)
        }):Play()
    end
end

